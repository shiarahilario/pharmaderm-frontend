# â”€â”€ EmailJS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Obtén estos valores en https://www.emailjs.com/
# 1. Crea una cuenta â†’ Email Services â†’ conecta Gmail/Outlook
# 2. Email Templates â†’ crea plantilla de orden y de cita
# 3. Account â†’ API Keys â†’ copia Public Key

# Public URL for the brand icon used in EmailJS templates.
# The file public/logo-icon.png is served at the site root automatically.
# Override only if deploying to a custom domain:
# VITE_PUBLIC_LOGO_ICON_URL=https://yourdomain.com/logo-icon.png

# Public app URL used to generate complete links for EmailJS buttons.
VITE_APP_PUBLIC_URL=http://localhost:5173

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_ORDER_TEMPLATE_ID_ES=
VITE_EMAILJS_ORDER_TEMPLATE_ID_EN=
VITE_EMAILJS_APPOINTMENT_TEMPLATE_ID_ES=
VITE_EMAILJS_APPOINTMENT_TEMPLATE_ID_EN=
VITE_EMAILJS_ROUTINE_TEMPLATE_ID_ES=
VITE_EMAILJS_ROUTINE_TEMPLATE_ID_EN=
VITE_EMAILJS_PUBLIC_KEY=

# â”€â”€ Supabase â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Obtén estos valores en https://supabase.com/
# 1. Crea proyecto â†’ Settings â†’ API
# 2. Copia Project URL y anon public key

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# â”€â”€ Configuración regional por defecto â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
VITE_DEFAULT_CURRENCY=USD
VITE_DEFAULT_COUNTRY=DO
VITE_DOP_EXCHANGE_RATE=59.40

# â”€â”€ Modo de datos â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# "local"    â†’ usa solo localStorage (sin backend)
# "supabase" â†’ usa Supabase cuando las variables estén configuradas
VITE_DATA_MODE=local

